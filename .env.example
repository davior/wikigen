# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Google Custom Search API credentials (for image search)
# 1. Enable Custom Search API at console.cloud.google.com and create an API key
# 2. Create a Programmable Search Engine at programmablesearchengine.google.com
#    with "Search the entire web" and "Image search" enabled, then copy the cx ID
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-programmable-search-engine-id

# Flask session secret — set to a long random string in production
FLASK_SECRET=change-me-to-a-random-string

# Port to listen on (default: 5055)
PORT=5055

# Directory for connections.json, history.json, and plans/ (default: current dir)
DATA_DIR=.

# Fallback wiki connection — used if no connections.json exists yet.
# You can also add connections via the UI instead of setting these.
WIKI_URL=https://yourwiki.example.com/w/api.php
WIKI_NAME=My Wiki
WIKI_USERNAME=Username@BotPasswordName
WIKI_PASSWORD=your-bot-password-here
